{
  "name": "opencode-antigravity-plugin",
  "build": { "dockerfile": "Dockerfile" },
  "forwardPorts": [11435],
  "portsAttributes": {
    "11435": { "label": "OpenAI-compatible endpoint", "onAutoForward": "silent" }
  },
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24",
      "pnpmVersion": "9.15.9"
    }
  },
  "postCreateCommand": "bash -lc 'if [ -f package.json ]; then pnpm install; fi && if [ -f pyproject.toml ]; then uv sync; fi'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
