{
  "name": "opencode-antigravity-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:unit": "vitest run tests/ts",
    "test:python": "uv run pytest",
