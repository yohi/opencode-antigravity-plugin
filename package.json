    "verify": "uv run ruff check backend/src tests/python && uv run pytest && pnpm test:unit"
  },
  "dependencies": {
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
